# Docker Compose deployment environment for Paperclip.
# Copy to `.env` in this directory (docker/) and fill in the values below.
# Compose loads it automatically: `docker compose --env-file docker/.env -f docker/docker-compose.yml up`
#
# NEVER commit the resulting .env — it holds production secrets.

# --- Database -----------------------------------------------------------------
# Strong, unique password. The DB container refuses to start without it.
# Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=
# Optional overrides (defaults shown):
# POSTGRES_USER=paperclip
# POSTGRES_DB=paperclip

# --- Auth ---------------------------------------------------------------------
# Signs session cookies AND the agent JWT key. In authenticated mode the server
# REJECTS the dev default "paperclip-dev-secret" and any value shorter than 24
# chars. Generate one with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# --- Public URL ---------------------------------------------------------------
# The externally reachable URL. Used for auth cookies AND the CSRF trusted-origin
# set for board mutations — in authenticated mode the browser Origin must match
# this (or PAPERCLIP_ALLOWED_HOSTNAMES), otherwise mutating requests get 403.
PAPERCLIP_PUBLIC_URL=http://localhost:3100
# Extra browser hostnames allowed for board mutations (comma-separated), if you
# serve the UI from more than one host:
# PAPERCLIP_ALLOWED_HOSTNAMES=board.example.com,paperclip.example.com

# --- Reverse proxy ------------------------------------------------------------
# REQUIRED (explicit) under authenticated + public exposure: the server refuses
# to boot if this is unset. It lets the server read the real client IP from
# X-Forwarded-For; rate limiting keys off the client IP, so without it all
# clients appear as the proxy IP and share one bucket (a few bad logins could
# throttle everyone). Set "1" (trust first hop) or a CIDR when behind a proxy,
# or "0" to declare a direct, no-proxy exposure where req.ip is already correct.
TRUST_PROXY=1

# --- Rate limiting (optional overrides; defaults are generous) -----------------
# PAPERCLIP_AUTH_RATELIMIT_MAX=50            # auth POSTs per window per client IP
# PAPERCLIP_AUTH_RATELIMIT_WINDOW_MS=900000  # 15 min
# PAPERCLIP_FAILED_AUTH_RATELIMIT_MAX=60     # failed bearer attempts per window

# --- Encrypted database backups (recommended) ---------------------------------
# Encrypt database backups at rest with AES-256-GCM so a compromise of the backup
# directory does not also yield the plaintext database. The KEY must be stored
# OUTSIDE the backup volume (this env, a secrets manager) — keeping it next to the
# backups defeats the purpose. Generate with: openssl rand -base64 32
# Restoring an encrypted (.enc) backup requires the same key.
# PAPERCLIP_DB_BACKUP_ENCRYPTED=true
# PAPERCLIP_DB_BACKUP_KEY=<openssl rand -base64 32>
# Optional: write backups to a directory off the secrets/database volume.
# PAPERCLIP_DB_BACKUP_DIR=/backups

# --- Cloud tenant trust headers (only if fronted by Paperclip Cloud) ----------
# If PAPERCLIP_CLOUD_TENANT_SERVER_TOKEN is set under public exposure, the server
# also requires an HMAC signing key so the upstream proxy signs tenant identity
# headers — otherwise a leaked token alone allows cross-tenant impersonation.
# PAPERCLIP_CLOUD_TENANT_HMAC_KEY=<shared signing key with the upstream proxy>

# --- Soft delete (recoverable companies/issues) -------------------------------
# Deleting a company or issue now soft-deletes it (hidden, but recoverable) and a
# daily purge job runs the irreversible cascade after this grace window. Min 1.
# PAPERCLIP_SOFT_DELETE_GRACE_DAYS=30

# --- Plugin credential allowlist (recommended with third-party plugins) -------
# Provider API keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, ...) are injected into the
# process env of plugins that declare the environment.drivers.register capability.
# Set this comma-separated allowlist of plugin ids to restrict which plugins may
# receive them (empty = none). Unset keeps the legacy behavior but logs a warning.
# PAPERCLIP_PLUGIN_CREDENTIAL_ALLOWLIST=paperclipai.plugin-anthropic,paperclipai.plugin-kubernetes

# --- Hardening (recommended after the first admin signs up) -------------------
# Disable open sign-up once your accounts exist, to close the takeover window.
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=true
