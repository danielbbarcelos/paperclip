# Docker Compose deployment environment for Paperclip.
# Copy to `.env` in this directory (docker/) and fill in the values below.
# Compose loads it automatically: `docker compose --env-file docker/.env -f docker/docker-compose.yml up`
#
# NEVER commit the resulting .env — it holds production secrets.

# --- Database -----------------------------------------------------------------
# Strong, unique password. The DB container refuses to start without it.
# Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=
# Optional overrides (defaults shown):
# POSTGRES_USER=paperclip
# POSTGRES_DB=paperclip

# --- Auth ---------------------------------------------------------------------
# Signs session cookies AND the agent JWT key. In authenticated mode the server
# REJECTS the dev default "paperclip-dev-secret" and any value shorter than 24
# chars. Generate one with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# --- Public URL ---------------------------------------------------------------
# The externally reachable URL. Used for auth cookies AND the CSRF trusted-origin
# set for board mutations — in authenticated mode the browser Origin must match
# this (or PAPERCLIP_ALLOWED_HOSTNAMES), otherwise mutating requests get 403.
PAPERCLIP_PUBLIC_URL=http://localhost:3100
# Extra browser hostnames allowed for board mutations (comma-separated), if you
# serve the UI from more than one host:
# PAPERCLIP_ALLOWED_HOSTNAMES=board.example.com,paperclip.example.com

# --- Reverse proxy ------------------------------------------------------------
# REQUIRED when running behind a reverse proxy/load balancer so the server reads
# the real client IP from X-Forwarded-For. Rate limiting keys off the client IP;
# without this, all clients appear as the proxy IP and share one bucket (a few
# bad logins could throttle everyone). e.g. "1" (trust first hop) or a CIDR.
# TRUST_PROXY=1

# --- Rate limiting (optional overrides; defaults are generous) -----------------
# PAPERCLIP_AUTH_RATELIMIT_MAX=50            # auth POSTs per window per client IP
# PAPERCLIP_AUTH_RATELIMIT_WINDOW_MS=900000  # 15 min
# PAPERCLIP_FAILED_AUTH_RATELIMIT_MAX=60     # failed bearer attempts per window

# --- Hardening (recommended after the first admin signs up) -------------------
# Disable open sign-up once your accounts exist, to close the takeover window.
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=true
