# Docker Compose deployment environment for Paperclip.
# Copy to `.env` in this directory (docker/) and fill in the values below.
# Compose loads it automatically: `docker compose --env-file docker/.env -f docker/docker-compose.yml up`
#
# NEVER commit the resulting .env — it holds production secrets.

# --- Database -----------------------------------------------------------------
# Strong, unique password. The DB container refuses to start without it.
# Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=
# Optional overrides (defaults shown):
# POSTGRES_USER=paperclip
# POSTGRES_DB=paperclip

# --- Auth ---------------------------------------------------------------------
# Signs session cookies AND the agent JWT key. In authenticated mode the server
# REJECTS the dev default "paperclip-dev-secret" and any value shorter than 24
# chars. Generate one with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# --- Public URL ---------------------------------------------------------------
# The externally reachable URL (used for trusted origins / cookies).
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# --- Hardening (recommended after the first admin signs up) -------------------
# Disable open sign-up once your accounts exist, to close the takeover window.
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=true
